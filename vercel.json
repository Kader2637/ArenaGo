{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/uploads/(.*)",
      "dest": "/tmp/backend/uploads/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/app.js"
    },
    {
      "src": "/((?!api/|uploads/).*)",
      "dest": "/frontend/$1"
    }
  ]
}